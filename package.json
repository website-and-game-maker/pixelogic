{
  "name": "pixelogic",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pixelogic — a nonogram (picross) logic-puzzle game with a rigorous solver, uniqueness-proving generator, and a custom puzzle editor.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  }
}
